# ==========================================
# 数据库配置
# ==========================================

# 开发环境（本地）使用 SQLite
DB_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# 生产环境（Vercel）使用 PostgreSQL
# DB_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# ==========================================
# NextAuth 配置
# ==========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-long"

# ==========================================
# JWT 配置
# ==========================================
JWT_SECRET="your-jwt-secret-here-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# ==========================================
# 抖音开放平台（可选）
# ==========================================
DOUYIN_CLIENT_KEY=""
DOUYIN_CLIENT_SECRET=""

# ==========================================
# 小红书开放平台（可选）
# ==========================================
XIAOHONGSHU_APP_ID=""
XIAOHONGSHU_APP_SECRET=""

# ==========================================
# 快手开放平台（可选）
# ==========================================
KUAISHOU_APP_ID=""
KUAISHOU_APP_SECRET=""

# ==========================================
# 文件存储配置
# ==========================================
UPLOAD_DIR="./uploads"
CDN_URL="http://localhost:3000"

# ==========================================
# Redis 缓存（可选，生产环境推荐）
# ==========================================
# REDIS_URL="redis://localhost:6379"

# ==========================================
# Vercel 部署说明
# ==========================================
# 1. 在 Vercel Dashboard 中设置以下环境变量：
#    - DB_PROVIDER=postgresql
#    - DATABASE_URL=<你的 PostgreSQL 连接字符串>
#    - NEXTAUTH_SECRET=<随机生成的密钥>
#    - JWT_SECRET=<随机生成的密钥>
#
# 2. 推荐使用 Neon 或 Supabase 免费的 PostgreSQL 数据库
#    - Neon: https://neon.tech
#    - Supabase: https://supabase.com
#
# 3. 部署命令会自动执行：
#    - prisma generate
#    - prisma migrate deploy
#    - next build
