# ==========================================
# 数据库配置
# ==========================================

# 开发环境（本地）使用 SQLite
# 注意：Prisma provider 已固定为 postgresql，本地开发也需要使用 PostgreSQL
# 或者使用本地 PostgreSQL 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/private_traffic"

# 生产环境（Vercel）使用 Neon PostgreSQL
# DATABASE_URL="postgresql://neondb_owner:npg_zH18sAZJiXbU@ep-nameless-leaf-a1j4sks7-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ==========================================
# NextAuth 配置
# ==========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-long"

# ==========================================
# JWT 配置
# ==========================================
JWT_SECRET="your-jwt-secret-here-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# ==========================================
# 抖音开放平台（可选）
# ==========================================
DOUYIN_CLIENT_KEY=""
DOUYIN_CLIENT_SECRET=""

# ==========================================
# 小红书开放平台（可选）
# ==========================================
XIAOHONGSHU_APP_ID=""
XIAOHONGSHU_APP_SECRET=""

# ==========================================
# 快手开放平台（可选）
# ==========================================
KUAISHOU_APP_ID=""
KUAISHOU_APP_SECRET=""

# ==========================================
# 文件存储配置
# ==========================================
UPLOAD_DIR="./uploads"
CDN_URL="http://localhost:3000"

# ==========================================
# Redis 缓存（可选，生产环境推荐）
# ==========================================
# REDIS_URL="redis://localhost:6379"

# ==========================================
# Vercel 部署说明
# ==========================================
# 1. 在 Vercel Dashboard 中设置以下环境变量：
#    - DATABASE_URL=postgresql://neondb_owner:npg_zH18sAZJiXbU@ep-nameless-leaf-a1j4sks7-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#    - NEXTAUTH_SECRET=<随机生成的密钥>
#    - JWT_SECRET=<随机生成的密钥>
#
# 2. 推荐使用 Neon 免费的 PostgreSQL 数据库
#    - Neon: https://neon.tech
#
# 3. 部署命令会自动执行：
#    - prisma generate
#    - prisma migrate deploy
#    - next build
#
# 注意：Prisma schema 中的 provider 已固定为 postgresql
# 本地开发也需要使用 PostgreSQL 数据库
